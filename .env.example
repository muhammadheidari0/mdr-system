APP_NAME=MDR App
APP_VERSION=0.1.0
DEBUG=true
APP_ENV=development
API_PREFIX=/api/v1
MDR_DATA_ROOT=
APP_UID=1000
APP_GID=1000
WEB_CONCURRENCY=1

# Database
# Local Docker PostgreSQL (development defaults):
DATABASE_URL=postgresql+psycopg://mdr:mdr@postgres:5432/mdr_app
POSTGRES_DB=mdr_app
POSTGRES_USER=mdr
POSTGRES_PASSWORD=mdr
READ_ONLY_MODE=false
SYNC_ADMIN_ON_START=false
COMPOSE_DATABASE_URL=postgresql+psycopg://mdr:mdr@postgres:5432/mdr_app
COMPOSE_READ_ONLY_MODE=false

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SKIP_TESTCLIENT=true
FEATURE_BIM_GATEWAY=true
FEATURE_BIM_SCHEDULE_APPROVAL=true
FEATURE_BIM_REVIT_WRITEBACK_SITELOGS=true
FEATURE_BIM_INBOX_GATEWAY=true
FEATURE_BIM_INBOX_APPROVAL=true
FEATURE_BIM_PLUGIN_HMAC=true
STORAGE_ALLOWED_ROOTS=
STORAGE_REQUIRE_ABSOLUTE_PATHS=true
STORAGE_VALIDATE_WRITABLE_ON_SAVE=true

# Security
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin bootstrap
ADMIN_EMAIL=admin@mdr.local
ADMIN_PASSWORD=ChangeMe#12345
ADMIN_FULL_NAME=System Administrator

# Test auth
TEST_ADMIN_EMAIL=admin@mdr.local
TEST_ADMIN_PASSWORD=ChangeMe#12345

# Storage integrations (optional)
GDRIVE_SERVICE_ACCOUNT_JSON=
GDRIVE_SHARED_DRIVE_ID=
OPENPROJECT_BASE_URL=
OPENPROJECT_API_TOKEN=
OPENPROJECT_CONNECT_TIMEOUT_SECONDS=5
OPENPROJECT_READ_TIMEOUT_SECONDS=10
OPENPROJECT_TLS_VERIFY=true
OPENPROJECT_DEFAULT_WORK_PACKAGE_ID=
# Legacy alias (optional)
OPENPROJECT_DEFAULT_PROJECT_ID=
NEXTCLOUD_BASE_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_APP_PASSWORD=
NEXTCLOUD_ROOT_PATH=
NEXTCLOUD_LOCAL_MOUNT_ROOT=
NEXTCLOUD_CONNECT_TIMEOUT_SECONDS=5
NEXTCLOUD_READ_TIMEOUT_SECONDS=10
NEXTCLOUD_TLS_VERIFY=true
