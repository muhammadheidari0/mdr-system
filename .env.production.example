APP_NAME=MDR App
APP_VERSION=0.1.0
APP_ENV=production
DEBUG=false
API_PREFIX=/api/v1
MDR_DATA_ROOT=/opt/mdr_data
MDR_DOMAIN=esms.example.com
POSTGRES_PORT_BIND=127.0.0.1:5432:5432
WEB_PORT_BIND=127.0.0.1:8000:8000
APP_UID=1000
APP_GID=1000
WEB_CONCURRENCY=2

# Database
POSTGRES_DB=mdr_app
POSTGRES_USER=mdr
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+psycopg://mdr:CHANGE_ME_STRONG_PASSWORD@postgres:5432/mdr_app
# Keep this equal to DATABASE_URL to avoid compose/runtime DSN mismatch.
COMPOSE_DATABASE_URL=postgresql+psycopg://mdr:CHANGE_ME_STRONG_PASSWORD@postgres:5432/mdr_app
READ_ONLY_MODE=false
SYNC_ADMIN_ON_START=false

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=180
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SKIP_TESTCLIENT=true
STORAGE_ALLOWED_ROOTS=/app/archive_storage,/app/data_store
STORAGE_REQUIRE_ABSOLUTE_PATHS=true
STORAGE_VALIDATE_WRITABLE_ON_SAVE=true

# Security
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin bootstrap (set real values before first start)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_FULL_NAME=System Administrator

# Storage integrations
GDRIVE_SERVICE_ACCOUNT_JSON=
GDRIVE_SHARED_DRIVE_ID=
OPENPROJECT_BASE_URL=
OPENPROJECT_API_TOKEN=
OPENPROJECT_CONNECT_TIMEOUT_SECONDS=5
OPENPROJECT_READ_TIMEOUT_SECONDS=10
OPENPROJECT_TLS_VERIFY=true
OPENPROJECT_DEFAULT_WORK_PACKAGE_ID=
# Legacy alias (optional)
OPENPROJECT_DEFAULT_PROJECT_ID=
