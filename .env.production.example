APP_NAME=MDR App
APP_VERSION=0.1.0
APP_ENV=production
DEBUG=false
API_PREFIX=/api/v1

# Database
POSTGRES_DB=mdr_app
POSTGRES_USER=mdr
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+psycopg://mdr:CHANGE_ME_STRONG_PASSWORD@postgres:5432/mdr_app
READ_ONLY_MODE=false
SYNC_ADMIN_ON_START=false

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SKIP_TESTCLIENT=true

# Security
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin bootstrap (set real values before first start)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_FULL_NAME=System Administrator
